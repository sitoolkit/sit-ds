{
  "name": "ldap",
  "protocol": "LDAP",
  "useTrustStore": false,
  "host": "${LDAP_HOST}",
  "port": "${LDAP_PORT}",
  "searchBase": "${LDAP_ROOT_DN}",
  "authScheme": "SIMPLE",
  "authRealm": null,
  "authUsername": "${LDAP_MANAGER_DN}",
  "connectionTimeoutSeconds": 30,
  "connectionRetryDelaySeconds": 300,
  "maxIncidentsCount": 3,
  "userBaseDn": "",
  "userSubtree": true,
  "userObjectClass": "${NEXUS_USER_OBJECTCLASS}",
  "userLdapFilter": "",
  "userIdAttribute": "${LDAP_LOGIN_ATTRIBUTE}",
  "userRealNameAttribute": "${LDAP_FULLNAME_ATTRIBUTE}",
  "userEmailAddressAttribute": "${LDAP_MAIL_ATTRIBUTE}",
  "userPasswordAttribute": "",
  "ldapGroupsAsRoles": true,
  "groupType": "DYNAMIC",
  "groupBaseDn": null,
  "groupSubtree": false,
  "groupObjectClass": null,
  "groupIdAttribute": null,
  "groupMemberAttribute": null,
  "groupMemberFormat": null,
  "userMemberOfAttribute": "objectClass",
  "authPassword": "${LDAP_MANAGER_PASSWORD}"
}
